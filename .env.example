####################################
# Directus – Render.com environment
# Copy these into your Render dashboard
# under the loans-directus service → Environment
####################################

# ── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
# PORT is injected automatically by Render (default: 10000)
PUBLIC_URL=https://loans-directus.onrender.com   # change to your actual URL

SECRET=<generate a long random string>            # Render can auto-generate this

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# These are set automatically via the fromDatabase binding in render.yaml
DB_CLIENT=pg
DB_HOST=<from render>
DB_PORT=5432
DB_DATABASE=loans
DB_USER=directus
DB_PASSWORD=<from render>
DB_SSL__REJECT_UNAUTHORIZED=false

# ── Cache ────────────────────────────────────────────────────────────────────
CACHE_ENABLED=false
# To enable Redis caching, add a Render Redis service and set:
# CACHE_ENABLED=true
# CACHE_STORE=redis
# REDIS=rediss://<user>:<password>@<host>:<port>

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ENABLED=true
CORS_ORIGIN=true           # restrict to your frontend domain in production:
                           # CORS_ORIGIN=https://your-app.vercel.app

# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_LOCATIONS=local
STORAGE_LOCAL_ROOT=/uploads   # mounted at the Render persistent disk

# ── Admin ────────────────────────────────────────────────────────────────────
# Set these ONLY in the Render dashboard — never commit real credentials
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=<strong password>

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
